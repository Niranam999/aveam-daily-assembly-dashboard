@echo off
chcp 65001 > nul
title AVEAM - Step 2 Clean Completed Jobs and Sync Board
color 0b

echo =====================================================================
echo          AVEAM ASSEMBLY PRODUCTION BOARD - STEP 2: CLEAN & SYNC
echo =====================================================================
echo.
echo [ขั้นตอนที่ 1/2] กำลังย้ายงานประกอบที่เสร็จสมบูรณ์ไปยังไฟล์ประวัติ...
echo ---------------------------------------------------------------------
python archive_completed_jobs.py
if %errorlevel% neq 0 (
    echo.
    echo [ERROR] เกิดข้อผิดพลาดในขั้นตอนการแยกไฟล์ประวัติ! ระบบหยุดทำงานชั่วคราว
    goto end
)

echo.
echo [ขั้นตอนที่ 2/2] กำลังซิงก์ข้อมูลงานที่เหลือขึ้นแดชบอร์ดฝ่ายผลิตคลาวด์...
echo ---------------------------------------------------------------------
python sync_excel_to_supabase.py
if %errorlevel% neq 0 (
    echo.
    echo [ERROR] เกิดข้อผิดพลาดในการซิงก์ข้อมูลขึ้นระบบคลาวด์!
    goto end
)

echo.
echo =====================================================================
echo                อัปเดตบอร์ดฝ่ายผลิตและจัดเก็บประวัติสำเร็จแล้ว!
echo =====================================================================
echo.

:end
echo กดปุ่มใดๆ เพื่อปิดหน้าต่างนี้...
pause > nul
